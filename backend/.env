APP_NAME="EE360 Farm API"
APP_ENV=local
APP_KEY=base64:YzlYvhM7i2HZeyJSLIXLFJyW20TxA3BtxH4Xaz1HY1g=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ─── Database (MySQL for XAMPP) ───
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ee360_farm
DB_USERNAME=root
DB_PASSWORD=

# ─── Sanctum (for CORS / SPA support) ───
# Comma-separated list of frontend domains that can authenticate
SANCTUM_STATEFUL_DOMAINS=your-frontend.vercel.app,localhost:5173

# ─── Session ───
SESSION_DRIVER=file
SESSION_LIFETIME=120

# ─── Cache ───
CACHE_STORE=file

# ─── CORS – allow your Vercel frontend ───
FRONTEND_URL=https://your-frontend.vercel.app
