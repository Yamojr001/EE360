APP_NAME="EE360 Farm API"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.yourdomain.com

LOG_CHANNEL=stack
LOG_LEVEL=error

# ─── Database (MySQL / MariaDB on your VPS) ───
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ee360_farm
DB_USERNAME=ee360user
DB_PASSWORD=your_secure_password

# ─── Sanctum (for CORS / SPA support) ───
# Comma-separated list of frontend domains that can authenticate
SANCTUM_STATEFUL_DOMAINS=your-frontend.vercel.app,localhost:5173

# ─── Session ───
SESSION_DRIVER=file
SESSION_LIFETIME=120

# ─── Cache ───
CACHE_STORE=file

# ─── CORS – allow your Vercel frontend ───
FRONTEND_URL=https://your-frontend.vercel.app
